# Database — Railway cung cấp tự động khi add PostgreSQL service
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Server port — Railway inject tự động, không cần set thủ công
PORT=4000

# JWT secrets — tạo bằng: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_use_random_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_use_random_64_chars_different
JWT_REFRESH_EXPIRES_IN=30d

# Admin JWT
JWT_ADMIN_SECRET=change_me_use_random_64_chars_for_admin
JWT_ADMIN_EXPIRES_IN=8h

# Frontend URL (dùng cho CORS) — điền sau khi deploy frontend
FRONTEND_URL=https://your-frontend.up.railway.app
